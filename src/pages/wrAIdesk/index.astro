          <tr class="cmd-cat"><th colspan="2">Konfiguracja (raz na początku)</th></tr>
          <tr><td><code>uruchom pill_onboarding</code></td><td>pierwsza rozmowa konfiguracyjna: dziedzina, odbiorcy, styl</td></tr>
          <tr><td><code>uruchom pill_kalibracja</code></td><td>dostarczenie próbki Twojego głosu (2-3 teksty)</td></tr>
          <tr class="cmd-cat"><th colspan="2">Praca</th></tr>
